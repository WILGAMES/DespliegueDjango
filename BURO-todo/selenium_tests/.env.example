# Copia este archivo como .env y completa los valores antes de correr las pruebas

# URL base de la aplicación desplegada
SELENIUM_BASE_URL=https://desplieguedjango.onrender.com

# Credenciales de usuario Secretaria (para TC-01 a TC-05)
SECRETARY_USER=correo_secretaria@icesi.edu.co
SECRETARY_PASS=contraseña_secretaria

# Credenciales de usuario Profesor (para TC-06 a TC-18)
PROFESSOR_USER=correo_profesor@icesi.edu.co
PROFESSOR_PASS=contraseña_profesor

# ID de un caso activo con estudiante asignado al profesor (para TC-06 a TC-18)
TEST_CASE_ID=1

# Número de caso que YA EXISTE en la BD (para TC-02 — duplicado)
EXISTING_CASE_NUMBER=CASO-2026-001

# Si SELENIUM_HEADLESS=false el navegador se abre visualmente (útil para depurar)
SELENIUM_HEADLESS=true

# Segundos de espera máxima para que aparezcan elementos en pantalla
SELENIUM_WAIT=20
